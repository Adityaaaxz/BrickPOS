// Prisma Schema for LEGO Landing Page
// Product catalog and Newsletter subscriber management

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  category  String
  image     String
  imageUrl  String?
  stock     Int      @default(0)
  pieces    Int      @default(0)
  ageRange  String   @default("6+")
  rating    Float    @default(4.5)
  createdAt DateTime @default(now())
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("staff")
  createdAt DateTime @default(now())
}
